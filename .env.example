ORDEROPS_ENV=local
ORDEROPS_APP_NAME=OrderOps Agent API
ORDEROPS_API_HOST=127.0.0.1
ORDEROPS_API_PORT=8000
ORDEROPS_API_RELOAD=1

ORDEROPS_POSTGRES_USER=orderops
ORDEROPS_POSTGRES_PASSWORD=orderops
ORDEROPS_POSTGRES_DB=orderops
ORDEROPS_POSTGRES_PORT=15432
ORDEROPS_DATABASE_URL=postgresql://orderops:orderops@localhost:15432/orderops

ORDEROPS_REDIS_PORT=6379
ORDEROPS_REDIS_URL=redis://localhost:6379/0

ORDEROPS_QDRANT_HTTP_PORT=6333
ORDEROPS_QDRANT_GRPC_PORT=6334
ORDEROPS_QDRANT_URL=http://localhost:6333
ORDEROPS_QDRANT_COLLECTION=orderops_policies

# RAG provider defaults keep the project runnable without model downloads.
# Local semantic option: ORDEROPS_EMBEDDING_PROVIDER=sentence_transformers
# API semantic option: ORDEROPS_EMBEDDING_PROVIDER=openai_compatible
ORDEROPS_EMBEDDING_PROVIDER=hashing
ORDEROPS_EMBEDDING_MODEL=hashing-token-v1
ORDEROPS_EMBEDDING_DIMENSION=384
ORDEROPS_EMBEDDING_API_BASE_URL=
ORDEROPS_EMBEDDING_API_KEY=
ORDEROPS_EMBEDDING_API_PATH=/v1/embeddings
ORDEROPS_EMBEDDING_QUERY_PREFIX=
ORDEROPS_EMBEDDING_DOCUMENT_PREFIX=

# Local neural option: ORDEROPS_RERANK_PROVIDER=cross_encoder
# API option: ORDEROPS_RERANK_PROVIDER=http
ORDEROPS_RERANK_PROVIDER=lexical
ORDEROPS_RERANK_MODEL=lexical-token-overlap-v1
ORDEROPS_RERANK_API_BASE_URL=
ORDEROPS_RERANK_API_KEY=
ORDEROPS_RERANK_API_PATH=/rerank
