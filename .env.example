ORDEROPS_ENV=local
ORDEROPS_APP_NAME=OrderOps Agent API
ORDEROPS_API_HOST=127.0.0.1
ORDEROPS_API_PORT=8000
ORDEROPS_API_RELOAD=1

ORDEROPS_POSTGRES_USER=orderops
ORDEROPS_POSTGRES_PASSWORD=orderops
ORDEROPS_POSTGRES_DB=orderops
ORDEROPS_POSTGRES_PORT=15432
ORDEROPS_DATABASE_URL=postgresql://orderops:orderops@localhost:15432/orderops

ORDEROPS_REDIS_PORT=6379
ORDEROPS_REDIS_URL=redis://localhost:6379/0

ORDEROPS_QDRANT_HTTP_PORT=6333
ORDEROPS_QDRANT_GRPC_PORT=6334
ORDEROPS_QDRANT_URL=http://localhost:6333
ORDEROPS_QDRANT_COLLECTION=orderops_policies

# Recommended real local RAG stack. Use local paths in your private .env
# after downloading model files, for example D:\models\bge-m3.
ORDEROPS_EMBEDDING_PROVIDER=sentence_transformers
ORDEROPS_EMBEDDING_MODEL=BAAI/bge-m3
ORDEROPS_EMBEDDING_DIMENSION=1024
ORDEROPS_EMBEDDING_API_BASE_URL=
ORDEROPS_EMBEDDING_API_KEY=
ORDEROPS_EMBEDDING_API_PATH=/v1/embeddings
ORDEROPS_EMBEDDING_QUERY_PREFIX=
ORDEROPS_EMBEDDING_DOCUMENT_PREFIX=

ORDEROPS_RERANK_PROVIDER=cross_encoder
ORDEROPS_RERANK_MODEL=BAAI/bge-reranker-v2-m3
ORDEROPS_RERANK_API_BASE_URL=
ORDEROPS_RERANK_API_KEY=
ORDEROPS_RERANK_API_PATH=/rerank

# Optional LLM planner/composer. Keep the real key only in your private .env.
ORDEROPS_LLM_PROVIDER=deepseek
ORDEROPS_LLM_API_KEY=
ORDEROPS_LLM_MODEL=deepseek-v4-pro
ORDEROPS_LLM_TEMPERATURE=0
ORDEROPS_LLM_MAX_TOKENS=1200
ORDEROPS_LLM_TIMEOUT_SECONDS=60
ORDEROPS_LLM_THINKING_ENABLED=0
ORDEROPS_LLM_REASONING_EFFORT=medium
# Usually leave these empty and let ORDEROPS_LLM_PROVIDER choose the preset.
ORDEROPS_LLM_API_BASE_URL=
ORDEROPS_LLM_API_PATH=/chat/completions

# SiliconFlow example:
# ORDEROPS_LLM_PROVIDER=siliconflow
# ORDEROPS_LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
